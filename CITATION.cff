    given-names: Ioannis
    email: tungolcild@gmail.com
    alias: depolarised
repository-code: "https://github.com/depolarised/artefaux"
repository-artifact: "https://github.com/depolarised/artefaux/releases/tag/v1.0.0"
keywords:
  - ECG
  - electrocardiography
  - signal quality
  - noise detection
  - lead failure
  - artefact
  - stress testing
  - robustness validation
